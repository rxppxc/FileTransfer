# ════════════════════════════════════════════════════════════════════════════
# FileTransfer SNM — Plantilla de variables de entorno
# Copia este archivo como `.env` y completa los valores. NO subas .env al repo.
# ════════════════════════════════════════════════════════════════════════════

# ───── Aplicación ─────
APP_NAME=FileTransfer - SNM
# development | staging | production
# Importante: en `production` se ocultan /api/docs y se restringe CORS.
APP_ENV=development

# Generar con: python -c "import secrets; print(secrets.token_urlsafe(48))"
# Rotar al menos cada 90 días. Cambiar invalida todas las sesiones activas.
SECRET_KEY=REEMPLAZAR_CON_CLAVE_GENERADA

# Duración del token (recomendado 60-480 minutos)
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# ───── Base de datos ─────
# Producción: usar usuario dedicado con permisos mínimos (no `postgres`)
# Ajusta el nombre de la BD si tu instancia usa otro nombre.
DATABASE_URL=postgresql+asyncpg://USUARIO:PASSWORD@HOST:5432/filetransfer

# ───── LDAP / Active Directory ─────
LDAP_HOST=192.168.X.X
LDAP_PORT=389
LDAP_BASE_DN=DC=ejemplo,DC=local
LDAP_BIND_USER=cuenta-servicio@ejemplo.local
LDAP_BIND_PASSWORD=REEMPLAZAR
LDAP_TIMEOUT=10
# Restringe login a una OU. Vacío = todo el dominio.
LDAP_ALLOWED_OU=

# ───── Archivos ─────
STORAGE_PATH=./storage/transfers
MAX_FILE_SIZE_MB=100
TRANSFER_EXPIRY_DAYS=7

# ───── SMTP ─────
MAIL_HOST=correo.ejemplo.local
MAIL_PORT=25
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@ejemplo.local
MAIL_FROM_NAME=FileTransfer

# ───── Mantenimiento ─────
# Cada N horas se eliminan transferencias expiradas. 0 = desactivado.
LIMPIEZA_INTERVALO_HORAS=6

# ───── CORS / URLs ─────
# Origen del frontend (dev usa Vite en :5173)
FRONTEND_URL=http://localhost:5173
# URL pública incluida en los correos
APP_URL=http://localhost:5173

# ───── Rate limiting ─────
# Descargas por IP por minuto (público). 0 desactiva el límite.
RATE_LIMIT_DOWNLOADS_PER_MINUTE=30
