# ════════════════════════════════════════════════════════════════════════════
# FileTransfer SNM — Variables para docker-compose-prod.yml
# Copiar como `.env` (en la raíz del repo, junto a docker-compose-prod.yml) y
# completar los valores reales. Docker Compose lo lee solo. NO subir el `.env`
# resultante al repo (el patrón `.env` en .gitignore ya lo cubre).
# ════════════════════════════════════════════════════════════════════════════

# ───── Base de datos (contenedor postgres_db) ─────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=REEMPLAZAR_CON_CONTRASENA_SEGURA
POSTGRES_DB=filetransfer

# ───── Aplicación ─────
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(48))"
# Rotar al menos cada 90 días. Cambiar invalida todas las sesiones activas.
SECRET_KEY=REEMPLAZAR_CON_CLAVE_GENERADA

# ───── LDAP / Active Directory ─────
LDAP_HOST=192.168.X.X
LDAP_BASE_DN=DC=ejemplo,DC=local
LDAP_BIND_USER=cuenta-servicio@ejemplo.local
LDAP_BIND_PASSWORD=REEMPLAZAR

# ───── SMTP ─────
MAIL_HOST=correo.ejemplo.local
MAIL_FROM=no-reply@ejemplo.local

# ───── URL pública del servidor (CORS + enlaces en correos) ─────
APP_URL=http://IP-O-DOMINIO-DEL-SERVIDOR
